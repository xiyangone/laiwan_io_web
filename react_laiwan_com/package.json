{
    "name": "webpack-react-tutorial",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start": "webpack-dev-server --open --mode development --host=0.0.0.0 --disable-host-check --useLocalIp",
        "start:visual": "cmd /c \"set NODE_OPTIONS=--openssl-legacy-provider&& webpack-dev-server --mode development --host 127.0.0.1 --disable-host-check --port 8080\"",
        "build": "webpack",
        "test": "jest",
        "lint": "eslint .",
        "test:visual": "playwright test -c playwright.visual.config.js",
        "test:visual:update": "playwright test -c playwright.visual.config.js --update-snapshots",
        "test:visual:report": "playwright show-report playwright-report",
        "test:visual:watch": "cmd /c \"set VISUAL_SCREENSHOT_DIR=..\\visual_regression\\test&& node test\\visual\\watch.js\""
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "lint-staged": {
        "src/**/*.{jsx,txs,ts,js,vue}": [
            "./node_modules/.bin/eslint --fix",
            "git add"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "12.1.2",
        "@types/jest": "^29.0.3",
        "babel-eslint": "10.1.0",
        "babel-loader": "8.0.6",
        "chokidar": "^5.0.0",
        "cross-fetch": "^3.1.5",
        "eslint": "5.16.0",
        "eslint-config-airbnb": "18.0.1",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "2.22.1",
        "eslint-plugin-jsx-a11y": "6.2.3",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "7.14.3",
        "eslint-plugin-react-hooks": "2.2.0",
        "html-loader": "0.5.5",
        "html-webpack-plugin": "3.2.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.0.3",
        "jest-environment-jsdom": "^29.0.3",
        "jest-transform-stub": "^2.0.0",
        "pixelmatch": "^7.1.0",
        "pngjs": "^7.0.0",
        "webpack": "4.42.0",
        "webpack-cli": "3.3.11"
    },
    "dependencies": {
        "@babel/plugin-proposal-class-properties": "7.8.3",
        "@material-ui/core": "4.9.5",
        "@material-ui/icons": "4.9.1",
        "axios": "0.19.2",
        "css-loader": "3.4.2",
        "file-loader": "^6.2.0",
        "husky": "4.2.3",
        "js-cookie": "^3.0.5",
        "lint-staged": "10.0.8",
        "qrcode.react": "3.1.0",
        "react": "16.13.0",
        "react-background-image": "1.2.0",
        "react-dom": "16.13.0",
        "react-icons": "3.9.0",
        "react-intl": "^6.6.4",
        "react-router": "5.1.2",
        "react-router-dom": "5.1.2",
        "style-loader": "1.1.3",
        "url-loader": "^4.1.1",
        "webpack-dev-server": "3.10.3"
    }
}
