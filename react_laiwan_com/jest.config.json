{
    "transform": {
        "^.+\\.[t|j]sx?$": "babel-jest"
    },
    "testTimeout": 20000,
    "verbose": true,
    "bail": 0,
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
        "^.+\\.(css|less|scss|sass)$": "identity-obj-proxy",
        ".+\\.(png|jpg|jpeg|gif|svg)$": "jest-transform-stub"
    },
    "setupFilesAfterEnv": ["<rootDir>/__test__/setup.js"]
}
